generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  username      String
  password      String
  email         String          @unique
  createdAt     DateTime        @default(now())
  lastUpdate    DateTime        @updatedAt
  avatarUrl     String?
  tokenVersion  Int             @default(0)
  watchProgress WatchProgress[] @relation("Users progress")
}

model Video {
  id            String          @id @default(uuid())
  name          String
  length        Int?
  thumbnail     String
  banner        String
  videotype     VideoType
  description   String?
  rls_year      Int?
  genre_id      Int
  createdAt     DateTime        @default(now())
  seasons       Season[]        @relation("VideoToSeason")
  genre         Genre           @relation(fields: [genre_id], references: [id])
  watchProgress WatchProgress[] @relation("Video Progression")
}

model Season {
  id         String    @id @default(uuid())
  name       String
  number     Int
  videoId    String
  createdAt  DateTime  @default(now())
  lastUpdate DateTime  @default(now()) @updatedAt
  episodes   Episode[] @relation("Episodes Season ")
  video      Video     @relation("VideoToSeason", fields: [videoId], references: [id])
}

model Episode {
  id            String          @id @default(uuid())
  title         String
  description   String?
  number        Int
  length        Int
  thumbnail     String?
  season_id     String
  createdAt     DateTime        @default(now())
  season        Season          @relation("Episodes Season ", fields: [season_id], references: [id], onDelete: Cascade)
  watchProgress WatchProgress[] @relation("Episode Progression")
}

model WatchProgress {
  id            String    @id @default(uuid())
  user_id       String
  episode_id    String?
  type          VideoType
  last_position BigInt
  isFinished    Boolean
  video_id      String?
  episode       Episode?  @relation("Episode Progression", fields: [episode_id], references: [id])
  user          User      @relation("Users progress", fields: [user_id], references: [id])
  video         Video?    @relation("Video Progression", fields: [video_id], references: [id])

  @@index([user_id, video_id])
  @@index([user_id, episode_id])
}

model Genre {
  name  String
  id    Int     @id @default(autoincrement())
  video Video[]
}

enum VideoType {
  MOVIE
  SERIES
}
